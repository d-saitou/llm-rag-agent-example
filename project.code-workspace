{
  "folders": [ // マルチルート・ワークスペース設定
    {
      "name": "Backend",
      "path": "backend"
    },
    {
      "name": "Frontend",
      "path": "frontend"
    },
    {
      "name": "Root",
      "path": "."
    }
  ],
  "settings": {
    "files.exclude": {
      "backend/": true, // Root内のbackendフォルダを隠す
      "frontend/": true // Root内のfrontendフォルダを隠す
    },
    "files.encoding": "utf8",
    "files.eol": "\n",
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "files.associations": {
      "*.secret": "plaintext",
      "*.key": "plaintext"
    },
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.formatOnSave": false,
    "[python]": { // .backend/devcontainer.jsonの"python"セクションと一致させること
      "editor.tabSize": 4,
      "editor.defaultFormatter": "charliermarsh.ruff",
      "editor.formatOnSave": true,
      "editor.codeActionsOnSave": {
        "source.fixAll.ruff": "always"
      }
    },
    "[powershell]": {
      "files.encoding": "utf8bom"
    },
    "[plaintext]": {
      "files.insertFinalNewline": false, // secrets用に行末の改行なしを許容
			"editor.quickSuggestions": {
        "comments": "off",
        "strings": "off",
        "other": "off"
      }
		}
  },
  "extensions": {
    "recommendations": [
      "ms-vscode-remote.vscode-remote-extensionpack", // Remote Development
      "ms-azuretools.vscode-docker",                  // Docker
      "ms-python.python",                             // Python
      "charliermarsh.ruff"                            // Python Linter/Formatter
    ]
  }
}
