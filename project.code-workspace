{
  "folders": [ // マルチルート・ワークスペース設定
    {
      "name": "Backend",
      "path": "backend"
    },
    {
      "name": "Frontend",
      "path": "frontend"
    },
    {
      "name": "Root",
      "path": "."
    }
  ],
  "settings": {
    "files.exclude": { // ファイル/フォルダ非表示設定
      "backend/": true,         // Root/backend  ※Root内非表示設定
      "frontend/": true,        // Root/frontend ※Root内非表示設定
      "**/node_modules/": true, // Frontend/node_modules ※コンテナのボリュームマウントで自動生成されるディレクトリの非表示設定
      "**/.next/": true         // Frontend/.next        ※コンテナのボリュームマウントで自動生成されるディレクトリの非表示設定
    },
    "files.encoding": "utf8",
    "files.eol": "\n",
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "files.associations": {
      "*.secret": "plaintext",
      "*.key": "plaintext"
    },
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.formatOnSave": false,
    "[python]": { // .backend/devcontainer.jsonの"python"セクションと一致させること
      "editor.tabSize": 4,
      "editor.defaultFormatter": "charliermarsh.ruff",
      "editor.formatOnSave": true,
      "editor.codeActionsOnSave": {
        "source.fixAll.ruff": "always"
      }
    },
    "[powershell]": {
      "files.encoding": "utf8bom"
    },
    "[plaintext]": {
      "files.insertFinalNewline": false, // secrets用に行末の改行なしを許容
			"editor.quickSuggestions": {
        "comments": "off",
        "strings": "off",
        "other": "off"
      }
		},
    "js/ts.validate.enabled": false // js/tsエラー無効化 ※frontendコンテナで開発するためprojectルートでは非表示
  },
  "extensions": {
    "recommendations": [
      "ms-vscode-remote.vscode-remote-extensionpack", // [Dev Host] Remote Development
      "ms-azuretools.vscode-docker",                  // [Dev Host] Docker
      "ms-python.python",                             // [Dev Host / Dev Container(backend)] Python
      "charliermarsh.ruff",                           // [Dev Host / Dev Container(backend)] Ruff
      "dbaeumer.vscode-eslint",                       // [Dev Host / Dev Container(frontend)] ESLint
      "esbenp.prettier-vscode",                       // [Dev Host / Dev Container(frontend)] Prettier
      "bradlc.vscode-tailwindcss",                    // [Dev Host / Dev Container(frontend)] Tailwind CSS IntelliSense
      "ms-vscode.js-debug-nightly"                    // [Dev Host / Dev Container(frontend)] JavaScript Debugger (Nightly)
    ]
  }
}
