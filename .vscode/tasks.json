{
  "version": "2.0.0",
  "tasks": [
    { // Docker Compose Up
      "label": "Dev Host: Docker Compose Up",
      "type": "shell",
      "command": "docker",
      "args": ["compose", "up", "-d"],
      "problemMatcher": []
    },
    { // Docker Compose Down
      "label": "Dev Host: Docker Compose Down",
      "type": "shell",
      "command": "docker",
      "args": ["compose", "down"],
      "problemMatcher": []
    },
    { // 開発コンテナ準備完了待機 (非表示タスク)
      "label": "Internal: Wait Dev Containers Ready",
      "type": "shell",
      "command": "bash",
      "args": ["-c", "docker compose logs -f | awk \"{ print } /Uvicorn running on/ { backend=1 } /Ready in [0-9]+ms/ { frontend=1 } backend && frontend { exit }\""],
      "problemMatcher": [],
      "hide": true
    },
    { // フルスタックデバッグ準備
      "label": "Dev Host: Prepare Full Stack Debug",
      "dependsOn": [
        "Dev Host: Docker Compose Up",
        "Internal: Wait Dev Containers Ready"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    { // Dev Container 起動時自動生成 Docker イメージ削除
      "label": "Dev Host: Cleanup VS Code DevContainer Images",
      "type": "shell",
      "command": "bash",
      "args": ["-c", "docker images --filter 'reference=vsc-*' -q | xargs -r docker rmi"],
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "revealProblems": "onProblem"
      }
    }
  ]
}
